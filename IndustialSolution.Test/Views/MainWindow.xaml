<Window
    x:Class="IndustialSolution.Test.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:IndustialSolution.Test"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:IndustialSolution.Test.ViewModels"
    Title="MainWindow"
    Width="800"
    Height="450"
    d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModel}"
    mc:Ignorable="d">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MaxWidth="200" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <!--  side  -->
        <ListView
            Grid.Column="0"
            DisplayMemberPath="UserDefinedName"
            ItemsSource="{Binding CamInfoList, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"
            SelectedItem="{Binding SelectedCameraInfo}"
            SelectionMode="Single" />


        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition MaxHeight="60" />
                <RowDefinition />
            </Grid.RowDefinitions>

            <!--  head  -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition MaxWidth="150" />
                    <ColumnDefinition MaxWidth="150" />
                    <ColumnDefinition MaxWidth="150" />
                    <ColumnDefinition MaxWidth="150" />
                </Grid.ColumnDefinitions>
                <Button
                    Grid.Column="0"
                    Width="130"
                    Height="30"
                    Command="{Binding EnumerateCamerasCommand}"
                    Content="Enumerate Camera" />

                <Button
                    Grid.Column="1"
                    Width="130"
                    Height="30"
                    Command="{Binding OpenCameraCommand}"
                    Content="Open Camera" />

                <Button
                    Grid.Column="2"
                    Width="130"
                    Height="30"
                    Command="{Binding StartGrabCommand}"
                    Content="Start Grab" />

                <Button
                    Grid.Column="3"
                    Width="130"
                    Height="30"
                    Command="{Binding SaveBmpCommand}"
                    Content="Save to Bitmap" />
            </Grid>

            <Grid Grid.Row="1">
                <StackPanel>

                    <Button
                        Grid.Column="3"
                        Width="130"
                        Height="30"
                        Command="{Binding SaveBmpCommand}"
                        Content="Close" />

                    <Image
                        Width="300"
                        Height="300"
                        Source="{Binding CurrentFrame, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

            </Grid>

        </Grid>
    </Grid>
</Window>
